# Deepgram API Key - Get yours at https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Anthropic API Key - Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Server config
PORT=3001
WS_PORT=3002

# Google Account credentials (for the bot to join meetings)
GOOGLE_EMAIL=your_bot_email@gmail.com
GOOGLE_PASSWORD=your_bot_password_here
